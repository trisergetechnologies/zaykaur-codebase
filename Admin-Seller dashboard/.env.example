# API origin ONLY: scheme + host + port. Do NOT append /api or /api/v1 (paths already include /api/v1/...).
# Examples: http://localhost:5000 (Express), http://localhost:4000 (api-gateway).
# Leave empty to use same-origin /api/... with Next.js rewrite to BACKEND_PROXY_URL / default 127.0.0.1:5000.
NEXT_PUBLIC_API_URL=http://localhost:5000

# Login page URL is /signin (not /sign-in). /sign-in redirects to /signin.

# Optional: where Next.js rewrites /api/* when NEXT_PUBLIC_API_URL is unset (default http://127.0.0.1:5000).
# BACKEND_PROXY_URL=http://127.0.0.1:5000

# Customer-facing web app URL (for redirecting customer role after login)
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000

# Run order: 1) MongoDB, 2) Express (server/, PORT e.g. 5000), 3) Dashboard (npm run dev)
