# Place the real file as server/.env (this folder), not the monorepo root.
PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/zaykaur
JWT_SECRET=wedfsiughsbvlidhsoilkasndlksbidiovsoidfvsifhvidohflnkxcv
# Access token TTL when REDIS_URL is set (short). Ignored for access when Redis is off (see JWT_EXPIRES_IN).
JWT_ACCESS_EXPIRES_IN=15m
# Access TTL when REDIS_URL is unset (single long-lived token mode for local dev without Redis).
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
# Comma-separated browser origins (storefront + Admin-Seller dashboard dev ports, etc.).
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Redis: when set, login returns short-lived access JWT + opaque refresh token stored in Redis (rotation on refresh).
# Leave empty to use legacy single long-lived JWT only (no refresh flow).
REDIS_URL=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ZayKaur <noreply@zaykaur.com>

# Cloudinary (required for POST /api/v1/upload — product images, avatars, etc.)
CLOUDINARY_CLOUD_NAME=dnnhl2rwl
CLOUDINARY_API_KEY=386975851281589
CLOUDINARY_API_SECRET=2Pv6HLu4w8ZxcSM_OK-GXXFYi10

# Razorpay
RAZORPAY_KEY_ID=
